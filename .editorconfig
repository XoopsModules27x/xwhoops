# EditorConfig — XOOPS module DevOps baseline. https://editorconfig.org
# xoops-overlay:profile=core27
root = true

[*]
charset = utf-8
indent_style = space
indent_size = 4
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = false

[*.{yml,yaml}]
indent_size = 2

[*.{html,tpl}]
indent_size = 2
